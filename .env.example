# 运行模式：mock 或 paimonsdk
APP_LLM_BACKEND=mock

# 密钥
QWEN_API_KEY=
MOONSHOT_API_KEY=sk-bbd92492fd5647fd8723b353ecdef420
OPENAI_API_KEY=

# 如果没有把 uu-work/main-v2 安装到当前环境，
# 可以直接填它的仓库根目录，程序会自动把 <repo>/src 加入 sys.path。
# 例如：/Users/you/code/uu-work
PAIMONSDK_SRC=

# provider / baseUrl / model / api / apiKeyEnv 请改到 config.json

# 生成参数
APP_TEMPERATURE=0.2
APP_MAX_TOKENS=2048

# 系统提示词
APP_SYSTEM_PROMPT=你是一个简洁、可靠的知识问答助手。仅根据给定的 Claims、Evidence、Source 回答；不确定时明确说明。
